<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Владислав — репетитор английского</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Public+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1E2A3F;
    --ink-soft:#3E4A5C;
    --paper:#EAF0E2;
    --paper-alt:#DEE7D2;
    --paper-deep:#CFDBC0;
    --amber:#D9A441;
    --amber-deep:#B8842B;
    --rust:#B5533C;
    --line:#B9C6A9;
    --white:#F8FAF4;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Public Sans', sans-serif;
    font-size:17px;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3{
    font-family:'Fraunces', serif;
    font-weight:500;
    margin:0;
    color:var(--ink);
  }
  .mono{
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:0.03em;
    text-transform:uppercase;
    font-size:13px;
  }
  a{color:inherit;}
  .wrap{max-width:920px;margin:0 auto;padding:0 28px;}

  /* NAV */
  nav{
    position:sticky;top:0;z-index:50;
    background:rgba(234,240,226,0.9);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line);
  }
  nav .wrap{
    display:flex;align-items:center;justify-content:space-between;
    padding-top:16px;padding-bottom:16px;
  }
  .nav-name{font-family:'Fraunces',serif;font-size:19px;font-weight:600;}
  .nav-links{display:flex;gap:24px;}
  .nav-links a{
    font-size:14px;text-decoration:none;color:var(--ink-soft);
    transition:color .15s;
  }
  .nav-links a:hover{color:var(--rust);}
  @media (max-width:600px){.nav-links{display:none;}}

  /* HERO */
  .hero{
    position:relative;
    padding:80px 0 110px;
    overflow:hidden;
  }
  .hero .wrap{position:relative;z-index:2;}
  .eyebrow{color:var(--amber-deep);margin-bottom:18px;display:block;}
  .hero h1{
    font-size:clamp(36px,6vw,56px);
    line-height:1.08;
    max-width:680px;
  }
  .hero h1 em{
    font-style:italic;color:var(--rust);
  }
  .hero p.lead{
    max-width:520px;
    margin-top:22px;
    font-size:18px;
    color:var(--ink-soft);
  }
  .hero-cta{
    margin-top:36px;
    display:flex;gap:14px;flex-wrap:wrap;
  }
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:13px 26px;
    border-radius:2px;
    font-size:15px;font-weight:500;
    text-decoration:none;
    border:1px solid var(--ink);
    transition:all .15s;
    cursor:pointer;
    background:transparent;
    font-family:inherit;
  }
  .btn-solid{
    background:var(--ink);color:var(--white);
  }
  .btn-solid:hover{background:var(--rust);border-color:var(--rust);}
  .btn-ghost:hover{background:var(--ink);color:var(--white);}

  .hero-inner{
    display:grid;
    grid-template-columns:1.3fr 0.9fr;
    gap:40px;
    align-items:center;
  }
  @media (max-width:820px){.hero-inner{grid-template-columns:1fr;}}
  .hero-photo-wrap{
    position:relative;
    justify-self:end;
  }
  @media (max-width:820px){.hero-photo-wrap{justify-self:start;order:-1;max-width:280px;}}
  .hero-photo{
    width:280px;
    aspect-ratio:2/3;
    object-fit:cover;
    border:1px solid var(--ink);
    filter:grayscale(0.15) contrast(1.03);
  }
  .hero-photo-tag{
    position:absolute;
    bottom:-14px;left:-14px;
    background:var(--ink);
    color:var(--white);
    padding:6px 12px;
    font-size:12px;
  }

  /* SECTION shell */
  section{padding:70px 0;}
  .section-alt{background:var(--paper-alt);}
  .section-head{
    display:flex;align-items:baseline;gap:16px;margin-bottom:44px;
    border-bottom:1px solid var(--line);
    padding-bottom:18px;
  }
  .section-head .mono{color:var(--rust);white-space:nowrap;}
  .section-head h2{font-size:clamp(26px,4vw,34px);}

  /* ROUTE / DIRECTIONS */
  .route-track{
    position:relative;
    padding-left:26px;
    border-left:2px dashed var(--line);
  }
  .stop{
    position:relative;
    padding:0 0 42px 22px;
  }
  .stop:last-child{padding-bottom:0;}
  .stop::before{
    content:'';
    position:absolute;left:-33.5px;top:4px;
    width:14px;height:14px;
    background:var(--paper);
    border:2px solid var(--rust);
    border-radius:50%;
  }
  .stop .stop-age{color:var(--ink-soft);}
  .stop h3{font-size:22px;margin:6px 0 8px;}
  .stop p{margin:0;color:var(--ink-soft);max-width:560px;font-size:15.5px;}

  /* ABOUT */
  .about-grid{
    display:grid;grid-template-columns:1fr 1.4fr;gap:48px;
  }
  @media (max-width:700px){.about-grid{grid-template-columns:1fr;}}
  .credential{
    border-top:1px solid var(--line);
    padding:16px 0;
  }
  .credential:first-child{border-top:none;}
  .credential .mono{color:var(--ink-soft);display:block;margin-bottom:6px;}
  .credential p{margin:0;font-size:15.5px;}
  .about-text p{margin:0 0 16px;color:var(--ink-soft);}
  .about-text p:last-child{margin-bottom:0;}

  /* METHOD */
  .method-grid{
    display:grid;grid-template-columns:repeat(2,1fr);gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  @media (max-width:600px){.method-grid{grid-template-columns:1fr;}}
  .method-card{
    background:var(--paper);
    padding:30px;
  }
  .section-alt .method-card{background:var(--paper-alt);}
  .method-card .mono{color:var(--amber-deep);display:block;margin-bottom:10px;}
  .method-card h3{font-size:19px;margin-bottom:8px;}
  .method-card p{margin:0;color:var(--ink-soft);font-size:15px;}

  /* MATERIALS / BOOK COVERS */
  .materials-intro{
    color:var(--ink-soft);
    max-width:600px;
    margin:0 auto 36px;
    font-size:15.5px;
  }
  .covers-grid{
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:22px 18px;
  }
  @media (max-width:900px){.covers-grid{grid-template-columns:repeat(4,1fr);}}
  @media (max-width:680px){.covers-grid{grid-template-columns:repeat(3,1fr);}}
  @media (max-width:460px){.covers-grid{grid-template-columns:repeat(2,1fr);}}
  .cover-item{display:flex;flex-direction:column;gap:10px;}
  .cover{
    aspect-ratio:3/4;
    border-radius:3px;
    display:flex;flex-direction:column;
    justify-content:space-between;
    padding:14px 12px;
    box-shadow:0 3px 10px rgba(30,42,63,0.18), inset 0 0 0 1px rgba(255,255,255,0.08);
    position:relative;
  }
  .cover::after{
    content:'';
    position:absolute;left:0;top:0;bottom:0;width:6px;
    background:rgba(0,0,0,0.15);
    border-radius:3px 0 0 3px;
  }
  .cover svg{width:26px;height:26px;stroke:currentColor;fill:none;stroke-width:1.6;}
  .cover-title{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:14.5px;
    line-height:1.15;
  }
  .cover-cap{
    font-size:12.5px;
    color:var(--ink-soft);
    text-align:center;
  }
  .cover-cap b{color:var(--ink);font-weight:600;}

  /* TESTIMONIALS */
  .testi-grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
  }
  @media (max-width:760px){.testi-grid{grid-template-columns:1fr;}}
  .testi-card{
    border:1px solid var(--line);
    padding:24px;
    background:var(--paper);
    display:flex;flex-direction:column;gap:16px;
    min-height:180px;
  }
  .testi-card .quote-mark{
    font-family:'Fraunces',serif;font-size:40px;color:var(--rust);
    line-height:0.5;
  }
  .testi-card p{margin:0;color:var(--ink-soft);font-style:italic;flex-grow:1;}
  .testi-card .who{font-style:normal;font-size:14px;color:var(--ink);font-weight:500;}
  .testi-placeholder{
    grid-column:1/-1;
    text-align:center;
    color:var(--ink-soft);
    font-size:14px;
    padding:14px;
    border:1px dashed var(--line);
  }

  /* CONTACT */
  .contact-block{
    text-align:center;
    padding:70px 0 90px;
  }
  .contact-block h2{font-size:clamp(28px,5vw,40px);max-width:600px;margin:0 auto 18px;}
  .contact-block p{color:var(--ink-soft);max-width:440px;margin:0 auto 34px;}
  .contact-links{
    display:flex;justify-content:center;gap:14px;flex-wrap:wrap;
  }
  .phone-line{
    margin-top:28px;
    font-family:'IBM Plex Mono',monospace;
    font-size:17px;
    letter-spacing:0.03em;
  }

  footer{
    padding:26px 0;border-top:1px solid var(--line);
    text-align:center;font-size:13px;color:var(--ink-soft);
  }

  .reveal{
    opacity:0;transform:translateY(16px);
    transition:opacity .6s ease, transform .6s ease;
  }
  .reveal.is-visible{opacity:1;transform:translateY(0);}
</style>
</head>
<body>

<nav>
  <div class="wrap">
    <div class="nav-name">Владислав</div>
    <div class="nav-links">
      <a href="#directions">Направления</a>
      <a href="#about">Обо мне</a>
      <a href="#method">Подход</a>
      <a href="#testimonials">Отзывы</a>
      <a href="#contact">Связаться</a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="wrap hero-inner">
    <div>
      <span class="eyebrow mono">Репетитор английского</span>
      <h1>Свой маршрут <em>к языку</em><br>для каждого ученика</h1>
      <p class="lead">От первых слов в 5 лет до академического английского для науки и карьеры. Работаю по международным программам, а не по школьным учебникам — со своей методикой, без стресса и штампов.</p>
      <div class="hero-cta">
        <a class="btn btn-solid" href="#contact">Написать мне</a>
        <a class="btn btn-ghost" href="#directions">Какие есть направления</a>
      </div>
    </div>
    <div class="hero-photo-wrap">
      <img class="hero-photo" src="data:image/jpeg;base64," alt="Владислав">
      <div class="hero-photo-tag mono">Владислав</div>
    </div>
  </div>
</section>

<section id="directions">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="mono">01 — Направления</span>
      <h2>У каждого свой этап пути</h2>
    </div>
    <div class="route-track">

      <div class="stop reveal">
        <span class="stop-age mono">от 5 лет</span>
        <h3>Малыши</h3>
        <p>Первое знакомство с языком через игру: карточки, песни, простые диалоги по Playway to English и Family and Friends. Задача этого возраста — не грамматика, а живой интерес и без страха ошибиться.</p>
      </div>

      <div class="stop reveal">
        <span class="stop-age mono">школьный возраст</span>
        <h3>Школьники</h3>
        <p>Занимаюсь по международным программам (Family and Friends, Prepare, Focus) — вместо школьных Spotlight и Starlight, которые не считаю рабочим инструментом. Так язык выстраивается системно, а не «для оценки».</p>
      </div>

      <div class="stop reveal">
        <span class="stop-age mono">9, 11 класс</span>
        <h3>ОГЭ и ЕГЭ</h3>
        <p>Если есть конкретный запрос на экзамен — прицельная подготовка: форматы заданий, тайминг, письменная часть и speaking. Разбираю не только «как решать», но и почему часто ошибаются именно в этом месте.</p>
      </div>

      <div class="stop reveal">
        <span class="stop-age mono">любой возраст</span>
        <h3>Олимпиады</h3>
        <p>Углублённая подготовка для тех, кому мало школьной программы: расширенная лексика, сложные тексты, олимпиадные форматы заданий.</p>
      </div>

      <div class="stop reveal">
        <span class="stop-age mono">взрослые</span>
        <h3>Взрослые ученики</h3>
        <p>Английский под конкретную цель — от нуля до разговорного уровня, вступительные экзамены в вуз, подготовка к собеседованиям.</p>
      </div>

      <div class="stop reveal">
        <span class="stop-age mono">взрослые / студенты</span>
        <h3>Академический английский</h3>
        <p>Помощь с научными работами и текстами на английском: структура, академический стиль, редактура.</p>
      </div>

    </div>
  </div>
</section>

<section id="about" class="section-alt">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="mono">02 — Обо мне</span>
      <h2>Образование и опыт</h2>
    </div>
    <div class="about-grid">
      <div>
        <div class="credential reveal">
          <span class="mono">Высшее образование</span>
          <p>Международные отношения, мировая политика и международный бизнес — с углублённым английским и испанским языками.</p>
        </div>
        <div class="credential reveal">
          <span class="mono">Магистратура</span>
          <p>Психолого-педагогическое образование, профиль «семейное консультирование». Это помогает объяснять сложное просто и находить подход к разным ученикам — от тревожных детей до взрослых с языковым барьером.</p>
        </div>
        <div class="credential reveal">
          <span class="mono">Опыт</span>
          <p>Веду частные занятия по английскому — от дошкольников до взрослых, от первого знакомства с языком до академических текстов.</p>
        </div>
      </div>
      <div class="about-text reveal">
        <p>Психологическое образование — не «для галочки»: оно каждый день помогает понимать, что стоит за ошибкой или нежеланием говорить на уроке, и выстраивать занятия так, чтобы результат был устойчивым, а не вымученным.</p>
        <p>Я принципиально работаю по международным учебным программам, а не по стандартным российским школьным учебникам — они не дают ни живого языка, ни системной базы. Исключение — если у ученика есть конкретная цель сдать ОГЭ, ЕГЭ или пройти олимпиаду: тогда добавляю прицельную подготовку под формат экзамена.</p>
        <p>Я не подгоняю всех учеников под один шаблон. Малышу нужна игра, подростку — интересный контент и структура, взрослому — конкретная цель и уважение к его времени.</p>
      </div>
    </div>
  </div>
</section>

<section id="method">
  <div class="wrap">
    <div class="section-head reveal">
      <span class="mono">03 — Подход</span>
      <h2>Как проходят занятия</h2>
    </div>
  </div>
  <div class="method-grid reveal">
    <div class="method-card">
      <span class="mono">Коммуникативный метод</span>
      <h3>Говорим с первых уроков</h3>
      <p>Грамматика — не самоцель, а инструмент, который появляется по мере необходимости в речи.</p>
    </div>
    <div class="method-card">
      <span class="mono">Через контент</span>
      <h3>Тексты, книги, темы по интересам</h3>
      <p>Материал подбираю под интересы ученика — так язык усваивается через содержание, а не зубрёжку.</p>
    </div>
    <div class="method-card">
      <span class="mono">Без давления</span>
      <h3>Комфортная среда</h3>
      <p>Ошибка — это часть процесса, а не повод для тревоги. Ученик должен хотеть говорить, а не бояться.</p>
    </div>
    <div class="method-card">
      <span class="mono">Индивидуальный темп</span>
      <h3>Подстраиваюсь под ученика</h3>
      <p>Кому-то нужно повторить тему трижды, кому-то — двигаться быстрее и глубже. Программа гибкая.</p>
    </div>
    <div class="method-card">
      <span class="mono">Игровой формат</span>
      <h3>Особенно с детьми</h3>
      <p>Карточки, игры, ролевые ситуации — то, что удерживает внимание и не превращает урок в рутину.</p>
    </div>
    <div class="method-card">
      <span class="mono">Для сильных учеников</span>
      <h3>Доп. материалы</h3>
      <p>Если ученику мало базовой программы — добавляю расширенные задания и более сложные тексты.</p>
    </div>
  </div>

  <div class="wrap" style="margin-top:64px;">
    <div class="section-head reveal">
      <span class="mono">По каким учебникам</span>
      <h2>Материалы, с которыми работаю</h2>
    </div>
    <p class="materials-intro reveal">Международные программы вместо школьных Spotlight/Starlight — выбираю серию под возраст, уровень и цель ученика.</p>

    <div class="covers-grid reveal">

      <!--
        КАК ВСТАВИТЬ СВОИ ФОТО ОБЛОЖЕК:
        В каждом блоке .cover ниже замените содержимое (SVG-иконку и подпись) на:
        <img src="cover-images/ИМЯ_ФАЙЛА.jpg" style="width:100%;height:100%;object-fit:cover;border-radius:3px;">
        и уберите style="padding" у родительского .cover (или оставьте — не критично).
        Файлы картинок положите в папку cover-images рядом с index.html.
        Ниже перед каждой обложкой указано предлагаемое имя файла.
      -->

      <!-- ФОТО: cover-images/super-safari.jpg -->
      <div class="cover-item">
        <div class="cover" style="background:#B08D2B;color:#fff;">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 12 Q12 6 20 12"/><path d="M2 20 Q12 14 22 20"/></svg>
          <div class="cover-title" style="color:#fff;">Super Safari</div>
        </div>
        <div class="cover-cap"><b>Cambridge</b> · малыши, движение и звуки</div>
      </div>

      <!-- ФОТО: cover-images/playway-to-english.jpg -->
      <div class="cover-item">
        <div class="cover" style="background:#B5533C;color:#fff;">
          <svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h5"/></svg>
          <div class="cover-title" style="color:#fff;">Playway to English</div>
        </div>
        <div class="cover-cap"><b>Cambridge</b> · от 5 лет</div>
      </div>

      <!-- ФОТО: cover-images/family-and-friends.jpg -->
      <div class="cover-item">
        <div class="cover" style="background:#D9A441;color:#1E2A3F;">
          <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.5-7 10-7 10z"/></svg>
          <div class="cover-title">Family and Friends</div>
        </div>
        <div class="cover-cap"><b>Oxford</b> · дошкольники, школьники</div>
      </div>

      <!-- ФОТО: cover-images/lets-go.jpg -->
      <div class="cover-item">
        <div class="cover" style="background:#7B5C6B;color:#fff;">
          <svg viewBox="0 0 24 24"><path d="M4 6h11a3 3 0 0 1 3 3v9H7a3 3 0 0 1-3-3V6z"/><path d="M4 6a3 3 0 0 1 3-3h4v3"/></svg>
          <div class="cover-title" style="color:#fff;">Let's Go</div>
        </div>
        <div class="cover-cap"><b>Oxford</b> · младшие школьники</div>
      </div>

      <!-- ФОТО: cover-images/story-central.jpg -->
      <div class="cover-item">
        <div class="cover" style="background:#5B4B8A;color:#fff;">
          <svg viewBox="0 0 24 24"><path d="M4 19V6a2 2 0 0 1 2-2h9l5 5v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M9 12l2 2 4-4"/></svg>
